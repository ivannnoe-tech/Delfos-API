# Delfos API - ambiente local
NODE_ENV=development
PORT=3001

# Banco principal do Delfos: configurações e metadados, não dados operacionais do cliente
DELFOS_DATABASE_URL=mongodb://localhost:27017/delfos

# JWT próprio
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Criptografia de credenciais de conexões externas
ENCRYPTION_KEY_BASE64=change-me-32-byte-base64-key

# Cache apenas em memória na Fase 1
CACHE_DRIVER=memory
CACHE_DEFAULT_TTL_S=300
CACHE_MAX_ITEMS=1000

# Consumo de APIs dos clientes
HTTP_TIMEOUT_MS=30000
HTTP_MAX_RETRIES=2
HTTP_RATE_LIMIT_PER_MINUTE=120

# CORS local
CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# Logs
LOG_LEVEL=info
LOG_REDACT_FIELDS=password,token,authorization,cookie,cpf,cnpj,email,phone
