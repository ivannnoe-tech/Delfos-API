# Delfos API - ambiente local
NODE_ENV=development
PORT=3000

# Banco principal do Delfos: configurações e metadados, não dados operacionais do cliente
DELFOS_DATABASE_URL=mongodb://localhost:27017/delfos

# PostgreSQL: banco primário futuro (ADR-0035), introduzido na fase P1 da migração.
# OPCIONAL nesta fase: se ausente, a API segue 100% em MongoDB e o health-check de
# Postgres é omitido. Se presente, habilita a conexão e o health-check de Postgres.
# Schema/migrations e a troca de repositórios vêm nas fases P2/P3.
DELFOS_POSTGRES_URL=postgresql://delfos:delfos@localhost:5432/delfos

# Auth temporaria da foundation/dev para endpoints administrativos protegidos.
# Substitua por um valor local forte. Nao use valor real em codigo, docs ou testes.
DELFOS_ADMIN_KEY=change-me-local-admin-key-at-least-32-chars

# JWT proprio - planejado/futuro, nao consumido pela foundation atual.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Criptografia de credenciais declarativas da foundation.
# Exemplo inseguro de desenvolvimento: gere uma chave local propria antes de usar.
ENCRYPTION_KEY_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# Valkey: cache layer (ADR-0035, fase P6). OPCIONAL: se ausente, o cache fica
# desligado (no-op) e o sistema serve tudo do banco. Se presente, habilita o
# CacheService com Valkey por tras. Toda chave tem TTL e namespace por tenant.
VALKEY_URL=redis://localhost:6379

# Cache legado - placeholders historicos, nao consumidos pelo bootstrap atual.
CACHE_DRIVER=memory
CACHE_DEFAULT_TTL_S=300
CACHE_MAX_ITEMS=1000

# Consumo de APIs dos clientes - planejado/futuro, sem conector real atual.
HTTP_TIMEOUT_MS=30000
HTTP_MAX_RETRIES=2
HTTP_RATE_LIMIT_PER_MINUTE=120

# Swagger UI em /docs (desabilitar em producao)
SWAGGER_ENABLED=true

# CORS local
# Origens permitidas separadas por virgula. Sem coringa: cada origem e exata
# (protocolo + host + porta), e localhost nao equivale a 127.0.0.1.
# 4174 = servidor estatico do E2E integrado do delfos-web (ver docs/e2e-web-testing.md).
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:3000,http://127.0.0.1:4174,http://localhost:4174

# Logs
LOG_LEVEL=info
LOG_REDACT_FIELDS=password,token,authorization,cookie,x-delfos-admin-key,cpf,cnpj,email,phone
