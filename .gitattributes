# Normalize all text files to LF in the repository.
* text=auto eol=lf

# Windows command scripts should use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts should always use LF.
*.sh text eol=lf

# Source code and config files.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env.example text eol=lf
*.dockerignore text eol=lf
Dockerfile text eol=lf

# Flutter / Dart files.
*.dart text eol=lf
*.arb text eol=lf
*.lock text eol=lf

# Styles and web assets.
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Binary files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
*.rar binary

# Font files are binary.
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
